# BioDjango v2.6.0 Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# =======================
# Django Settings
# =======================
SECRET_KEY=your-super-secret-key-here-change-in-production
DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1 [::1] web your-domain.com

# =======================
# Database Configuration
# =======================
POSTGRES_DB=biodjango
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-database-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# =======================
# Celery / Redis
# =======================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# =======================
# BLAST Database Path
# =======================
# Path on HOST machine where BLAST database is stored
# Example: /mnt/data/blastdb
BLAST_DB_PATH=/mnt/data/blastdb

# =======================
# CORS Settings (optional)
# =======================
# Only enable if frontend and backend are on different domains
# CORS_ALLOW_ALL_ORIGINS=False
